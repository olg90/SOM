def getiexta(f, taui0, tauy0, kiy0,
            taui1, tauy1, kiy1,
            dt, r,
            m01, b01, m04, b04,
            m11, b11, m14, b14,
            A00, A10):

    # ---------- spike times ----------
    pretimes = np.array([int(i / f / dt) + 1002 for i in range(10)])
    runtime = pretimes[-1]

    # ---------- frequency interpolation ----------
    m0f = zform(m01, m04, 10, 40, f)
    b0f = zform(b01, b04, 10, 40, f)
    m1f = zform(m11, m14, 10, 40, f)
    b1f = zform(b11, b14, 10, 40, f)

    # ---------- g(delta t) ----------
    def g(dt_i):
        return 0.001 / (dt_i*3 + 1e-12)

    # ---------- state ----------
    I0 = np.zeros(runtime)
    I1 = np.zeros(runtime)
    y0 = np.zeros(runtime)
    y1 = np.zeros(runtime)

    A0 = A00
    A1 = A10

    last_spike = [0, 0]  # slow, fast

    # ---------- simulation ----------
    for i in range(1, runtime):

        # check spike
        spike = (i in pretimes)

        if spike:

            # -------- slow pathway spike --------
            dt0 = (i - last_spike[0]) * dt
            A0 += g(dt0)

            y0[i - 1] += A0  # delta input
            last_spike[0] = i

            # -------- fast pathway spike --------
            dt1 = (i - last_spike[1]) * dt
            A1 += g(dt1)

            y1[i - 1] += A1
            last_spike[1] = i

        # ---------- y dynamics ----------
        y0[i] = y0[i - 1] + (-y0[i - 1] / tauy0) * dt
        y1[i] = y1[i - 1] + (-y1[i - 1] / tauy1) * dt

        # ---------- I dynamics ----------
        I0[i] = I0[i - 1] + (-I0[i - 1] / taui0 + kiy0 * y0[i - 1]) * dt
        I1[i] = I1[i - 1] + (-I1[i - 1] / taui1 + kiy1 * y1[i - 1]) * dt

    # ---------- combine ----------
    Iext = (1 - r) * I0 + r * I1

    return Iext, I0, I1, y0, y1, runtime, None, None

