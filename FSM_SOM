def linfun(s1,s4,fast1,fast4,f,r):
    return zform(s1,s4, 10,40,f)*(1-r)+zform(fast1,fast4, 10,40,f)*r

def get_slopes_and_fit_lin(file_path):
    # Load the Excel file
    df = pd.read_excel(file_path)
    col_slopes = []
    for col in df.columns:
        y = df[col].dropna().values
        x = np.arange(len(y))
        if len(y) > 1:
            slope, _, _, _, _ = linregress(x, y)
            col_slopes.append(slope)
        else:
            col_slopes.append(np.nan)
    col_slopes = np.array(col_slopes)

    # Frequencies
    freq = np.array([5, 10, 20, 40])
    valid = ~np.isnan(col_slopes)
    slope_fit, intercept_fit, _, _, _ = linregress(freq[valid], col_slopes[valid])
    best_fit_line = intercept_fit + slope_fit * freq

    return freq, col_slopes, best_fit_line, slope_fit, intercept_fit

def make_normalized_template(td, tr, tmax, dt, scale_I):
    # SynKernel = A * ( exp(-(x)/tauDecay) - exp(-(x)/tauRise) )
    t = np.arange(0, tmax, dt)
    A = scale_I / (-(tr/td)**(td/(td-tr)) + (tr/td)**(tr/(td-tr)))
    template = A * (np.exp(-t / td) - np.exp(-t / tr))
    return t, template

