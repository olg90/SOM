def linfun(s1,s4,fast1,fast4,f,r):
    return zform(s1,s4, 10,40,f)*(1-r)+zform(fast1,fast4, 10,40,f)*r


def make_normalized_template(td, tr, tmax, dt, scale_I):
    # SynKernel = A * ( exp(-(x)/tauDecay) - exp(-(x)/tauRise) )
    t = np.arange(0, tmax, dt)
    A = scale_I / (-(tr/td)**(td/(td-tr)) + (tr/td)**(tr/(td-tr)))
    template = A * (np.exp(-t / td) - np.exp(-t / tr))
    return t, template

def generate_spike_train(f, tmax, dt, template0, template1, p0, p1, M0, M1):
    t = np.arange(0, tmax, dt)
    out = np.zeros_like(t)
    L = len(t)
    Ltemp = len(template0)

    tcurr = 0
    timer = dt
    e = 1e-6

    while tcurr < tmax:
        t0 = np.random.exponential(1/(f+e))

        if t0 < timer:
            pos = int(tcurr/dt)
            end = min(pos + Ltemp, L)
            
            out[pos:end] += np.random.binomial(M0, p0)*template0[:end-pos]
            out[pos:end] += np.random.binomial(M1, p1)*template1[:end-pos]
            
            timer -= t0
            tcurr += t0
        else:
            tcurr += timer
            timer = dt

    return t, out

def generate_spike_train_det(f, tmax, dt, template0, template1, p0, p1, M0, M1):
    t = np.arange(0, tmax, dt)
    out = np.zeros_like(t)

    L = len(t)
    Ltemp = len(template0)

    # deterministic AP spacing
    isi = 1.0 / f
    spike_times = np.arange(0, tmax, isi)

    for ts in spike_times:
        pos = int(ts / dt)
        if pos >= L:
            break

        end = min(pos + Ltemp, L)

        # stochastic release
        k0 = np.random.binomial(M0, p0)
        k1 = np.random.binomial(M1, p1)

        out[pos:end] += k0 * template0[:end-pos]
        out[pos:end] += k1 * template1[:end-pos]

    return t, out

def gettmean(r, Iext, g, vb, C, Cr, f):
    v=np.zeros(len(Iext))
    v[0]=-60
    apinds=[]
    refper=40 # refper *dt (sec) = 4ms
    aptimer=np.inf
    posttimer=False
    gfast=zform(g[6], g[7], 10, 40, f)
    gslow=zform(g[10], g[11], 10, 40, f)
    gfast2=zform(gr[6], gr[7], 10, 40, f)
    gslow2=zform(gr[10], gr[11], 10, 40, f)
    vbslow=zform(vb[10], vb[11], 10, 40, f)
    vbfast=zform(vb[6], vb[7], 10, 40, f)
    C1=linfun(C[10], C[11], C[6], C[7], f, r)
    C2=linfun(Cr[10], Cr[11], Cr[6], Cr[7], f, r)
    vreset=linfun(vbr[10], vbr[11], vbr[6], vbr[7], f, r)
    
    for i in range(1,len(Iext)):
        if posttimer==False:
            icurr = r*gfast*(v[i-1]-vbfast)+(1-r)*gslow*(v[i-1]-vbslow)
            dvdt=((-icurr+Iext[i-1]))/C1
        if posttimer==True:
            icurr = r*gfast2*(v[i-1]-vbfast)+(1-r)*gslow2*(v[i-1]-vbslow)
            dvdt=((-icurr+Iext[i-1]))/C2
            
        if aptimer == np.inf:
            v[i] = v[i-1]+dvdt*dt
        else:
            v[i] = v[i-1]

        if Iext[i]>Iext[i-1]:
            posttimer=False

        if aptimer != np.inf:
            aptimer-=1
        if v[i-1]>linfun(vth[10], vth[11], vth[6], vth[7], f, r):
            v[i]=vreset
            apinds.append(i)
            aptimer=refper
            posttimer=True
        if aptimer==0:
            aptimer=np.inf
    aptimes=np.array(apinds)*dt
    naps=len(aptimes)
    ssaptimes=aptimes[int(0.3*len(aptimes)):]
    tmean = np.mean(np.diff(ssaptimes))
    return v, tmean, naps, aptimes

