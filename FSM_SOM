import numpy as np
import matplotlib.pyplot as plt
import os
import pandas as pd
from scipy.signal import find_peaks

def zform(z1,z2, f1,f2,f):
    return z1+(z2-z1)/(f2-f1)*(f-f1)

def getiext(f, taui0, tauy0, kiy0,
            taui1, tauy1, kiy1,
            dt, r, p1, ss0, ss1,
            tmax, extra=0, seed=None):

    T = tmax

    if seed is not None:
        np.random.seed(seed)

    # --------------------------------------------------
    # Deterministic spike times (periodic instead of Poisson)
    # --------------------------------------------------
    isi = 1.0 / f
    pretimes = np.arange(isi, T, isi)

    spike_idx = (pretimes / dt).astype(int)
    runtime = int(spike_idx.max() + extra + 1)

    # --------------------------------------------------
    # Keep routing random
    # --------------------------------------------------
    route = np.random.rand(len(spike_idx)) < r

    # --------------------------------------------------
    # Keep coincidence random
    # --------------------------------------------------
    duplicate = np.random.rand(len(spike_idx)) < p1

    spike_to_y0 = np.zeros(runtime, dtype=bool)
    spike_to_y1 = np.zeros(runtime, dtype=bool)

    # Primary assignment
    spike_to_y0[spike_idx[~route]] = True
    spike_to_y1[spike_idx[route]] = True

    # Coincidence duplication
    spike_to_y0[spike_idx[route & duplicate]] = True
    spike_to_y1[spike_idx[~route & duplicate]] = True

    # --------------------------------------------------
    # Dynamics (unchanged)
    # --------------------------------------------------
    y0 = np.zeros(runtime)
    y1 = np.zeros(runtime)
    I0 = np.zeros(runtime)
    I1 = np.zeros(runtime)

    for i in range(1, runtime):

        if spike_to_y0[i]:
            y0[i-1] = ss0
        if spike_to_y1[i]:
            y1[i-1] = ss1

        y0[i] = y0[i-1] + dt * (-y0[i-1] / tauy0)
        y1[i] = y1[i-1] + dt * (-y1[i-1] / tauy1)

        I0[i] = I0[i-1] + dt * (-I0[i-1] / taui0 + kiy0 * y0[i-1])
        I1[i] = I1[i-1] + dt * (-I1[i-1] / taui1 + kiy1 * y1[i-1])

    Iext = (1 - r) * I0 + r * I1

    return Iext, I0, I1, y0, y1, runtime, spike_idx




