    for col in df.columns:
        y = df[col].dropna().values
        x = np.arange(len(y))
        if len(y) > 1:
            slope, _, _, _, _ = linregress(x, y)
            col_slopes.append(slope)
        else:
            col_slopes.append(np.nan)

    col_slopes = np.array(col_slopes)

    freq = np.array([5, 10, 20, 40])
    delta_t = 1 / freq

    return delta_t, col_slopes

def get_slopes_and_fit_lin(file_path):
