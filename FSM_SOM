def zform(z1,z2, f1,f2,f):
    return z1+(z2-z1)/(f2-f1)*(f-f1)

def getiext(f, taui0, tauy0, kiy0,
            taui1, tauy1, kiy1,
            dt, r,
            m01, b01, m04, b04,
            m11, b11, m14, b14):

    pretimes = [int(i / f / dt) + 1002 for i in range(0, 10)]
    extra = 2000
    runtime = pretimes[-1] + extra

    # Frequency scaling for slopes and intercepts
    m0f = zform(m01, m04, 10, 40, f)
    b0f = zform(b01, b04, 10, 40, f)
    m1f = zform(m11, m14, 10, 40, f)
    b1f = zform(b11, b14, 10, 40, f)

    # Presizes for each current
    presizes0 = m0f * np.linspace(0, runtime * dt, runtime) + b0f
    presizes1 = m1f * np.linspace(0, runtime * dt, runtime) + b1f

    # Initialize arrays
    I0 = np.zeros(runtime)
    I1 = np.zeros(runtime)
    y0 = np.zeros(runtime)
    y1 = np.zeros(runtime)

    # Time evolution
    for i in range(0, runtime):
        if i in pretimes:
            y0[i - 1] = presizes0[i]  # reset just before update
            y1[i - 1] = presizes1[i]

        # Separate y decays
        dy0 = -y0[i - 1] / tauy0
        dy1 = -y1[i - 1] / tauy1
        y0[i] = y0[i - 1] + dy0 * dt
        y1[i] = y1[i - 1] + dy1 * dt

        # Update each current separately
        dI0 = -I0[i - 1] / taui0 + kiy0 * y0[i - 1]
        dI1 = -I1[i - 1] / taui1 + kiy1 * y1[i - 1]
        I0[i] = I0[i - 1] + dI0 * dt
        I1[i] = I1[i - 1] + dI1 * dt

    # Weighted sum for Iext
    Iext = (1 - r) * I0 + r * I1

    return Iext, I0, I1, y0, y1, runtime, presizes0, presizes1


def getstats(f, taui0, tauy0, kiy0, taui1, tauy1, kiy1, dt, r, 
                                 m01, b01, m04, b04, m11, 
                                 b11, m14, b14, g, vb, dnum, C, Cr, vd):
    # Fix fin plot
    rlist=np.linspace(0,1,100)
    tlist=[]
    rateslist=[]
    napslist=[]
    for ind,r in enumerate(rlist):
        print(ind, len(rlist))
        Iext, _, _, _, _, runtime, _, _ = getiext(f, taui0, tauy0, kiy0, 
                                         taui1, tauy1, kiy1, dt, r, 
                                         m01, b01, m04, b04, m11, 
                                         b11, m14, b14)
        _, tmean, naps, _ = gettmean(r, Iext, g, vb, dnum, C, Cr, vd, f)
        rateslist.append(naps/runtime/dt)
        tlist.append(tmean)
        napslist.append(naps)
    foutlist=1/np.array(tlist)
    return rlist, foutlist, napslist

