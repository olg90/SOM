    runtime = int(tmax / dt)
    spike_idx = spike_idx[spike_idx < runtime]

    # ---------- routing + duplication ----------
    route = np.random.rand(len(spike_idx)) < r
    duplicate = np.random.rand(len(spike_idx)) < p1

    spike_y0 = list(spike_idx[~route])
    spike_y1 = list(spike_idx[route])

    spike_y0 += list(spike_idx[route & duplicate])
    spike_y1 += list(spike_idx[~route & duplicate])

    spike_y0 = np.array(sorted(spike_y0))
    spike_y1 = np.array(sorted(spike_y1))

    # ---------- safe ISI ----------
    if len(spike_y0) > 1:
        isi_y0 = np.diff(spike_y0) * dt
    else:
        isi_y0 = np.array([])

    if len(spike_y1) > 1:
        isi_y1 = np.diff(spike_y1) * dt
    else:
        isi_y1 = np.array([])

    # ---------- amplitudes ----------
    amps_y0 = np.zeros(len(spike_y0))
    amps_y1 = np.zeros(len(spike_y1))

    if len(spike_y0) > 0:
        amps_y0[0] = A0
    if len(spike_y1) > 0:
        amps_y1[0] = A1

    if len(spike_y0) > 1:
        amps_y0[1:] = spike_amplitude(isi_y0, slope0, A0, c0, H0)

    if len(spike_y1) > 1:
        amps_y1[1:] = spike_amplitude(isi_y1, slope1, A1, c1, H1)

    # ---------- currents ----------
    I0 = np.zeros(runtime)
    I1 = np.zeros(runtime)

    L0 = len(template0)
