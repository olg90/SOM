def generate_spike_train(f, tmax, dt, template0, template1, p0, p1, M0, M1):
    t = np.arange(0, tmax, dt)
    out = np.zeros_like(t)
    L = len(t)
    Ltemp = len(template0)

    tcurr = 0
    timer = dt
    e = 1e-6

    while tcurr < tmax:
        t0 = np.random.exponential(1/(f+e))

        if t0 < timer:
            pos = int(tcurr/dt)
            end = min(pos + Ltemp, L)
            
            out[pos:end] += np.random.binomial(M0, p0)*template0[:end-pos]
            out[pos:end] += np.random.binomial(M1, p1)*template1[:end-pos]
            
            timer -= t0
            tcurr += t0
        else:
            tcurr += timer
            timer = dt

    return t, out

