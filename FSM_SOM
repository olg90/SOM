            aptimer=np.inf
    aptimes=np.array(apinds)*dt
    naps=len(aptimes)
    ssaptimes=aptimes[int(0.3*len(aptimes)):]
    tmean = np.mean(np.diff(ssaptimes))
    return v, tmean, naps, aptimes


def getiextd2(f,
             dt, r, p1,
             A0, A1,
             slope0, slope1,
             intercept0, intercept1,
             td0, tr0,
             td1, tr1):
    
    def Aadd(delta_t, slope, intercept):
        return slope/(delta_t+1e-12)+intercept
    
    nspikes=10
    i0list= np.zeros(int(nspikes/f*1/dt))
    i1list=np.zeros_like(i0list)
    A0prev=A0
    A1prev=A1
    A0list=[]
    A1list=[]
    A0list.append(A0prev)
    A1list.append(A1prev)
    spikeind0=[0]
    spikeind1=[0]
    
    tspikeprev0=0
    tspikeprev1=0
    tspikeindprev0=0
    tspikeindprev1=0
    
    for i in range(1,nspikes):
        tspike=1/f
        tspikeind=int(tspike*1/dt)
        branch = np.random.uniform(0,1)<r
        coincident = np.random.uniform(0,1)<p1
        
        if branch==0:
            # print(i, Aadd(tspikeprev0+tspike, slope0, intercept0))
            A0list.append(A0list[-1] + Aadd(tspikeprev0+tspike, slope0, intercept0)*tspike)
            tspikeprev0=0
            spikeind0.append(spikeind0[-1]+tspikeind+tspikeindprev0)
            tspikeindprev0=0
            if coincident==1:
                A1list.append(A1list[-1] + Aadd(tspikeprev1+tspike, slope1, intercept1)*tspike)
                tspikeprev1=0
                spikeind1.append(spikeind1[-1]+tspikeind+tspikeindprev1)
                tspikeindprev1=0
            else:
                tspikeindprev1+=tspikeind
                tspikeprev1+=tspike
            
        else: # branch == 1
            A1list.append(A1list[-1] + Aadd(tspikeprev1+tspike, slope1, intercept1)*tspike)
            tspikeprev1=0
            spikeind1.append(spikeind1[-1]+tspikeind+tspikeindprev1)
            tspikeindprev1=0
            # print(i, Aadd(tspikeprev1+tspike, slope1, intercept1))
            if coincident==1:
                # print(i, Aadd(tspikeprev0+tspike, slope0, intercept0)*tspike)
                A0list.append(A0list[-1] + Aadd(tspikeprev0+tspike, slope0, intercept0)*tspike)
                tspikeprev0=0
                spikeind0.append(spikeind0[-1]+tspikeind+tspikeindprev0)
                tspikeindprev0=0
            else:
                tspikeindprev0+=tspikeind
                tspikeprev0+=tspike
    
    for i, tind in enumerate(spikeind0):
        t, temp0 = make_normalized_template(td0, tr0, 11/f, dt, A0list[i])
        i0list[spikeind0[i]:] = temp0[:len(i0list)-spikeind0[i]]
    for i, tind in enumerate(spikeind1):
        t, temp1 = make_normalized_template(td1, tr1, 11/f, dt, A1list[i])
        i1list[spikeind1[i]:] = temp1[:len(i1list)-spikeind1[i]]
        
    I = (1-r)*i0list+r*i1list
    
    return I, i0list, i1list, A0list, A1list, spikeind0, spikeind1

