import numpy as np
import matplotlib.pyplot as plt
import os
import pandas as pd
from scipy.signal import find_peaks
from scipy.stats import linregress

# =========================================================
# HELPERS (UNCHANGED)
# =========================================================

def zform(z1,z2, f1,f2,f):
    return z1+(z2-z1)/(f2-f1)*(f-f1)

def linfun(s1,s4,fast1,fast4,f,r):
    return zform(s1,s4, 10,40,f)*(1-r)+zform(fast1,fast4, 10,40,f)*r

# =========================================================
# NEW LINEAR MODEL
# =========================================================

def model(delta_t, a, b):
    return a / delta_t + b

def spike_amplitude(delta_t, a, b, S_prev):
    # S(n+1) = S(n) + m(dt)*dt
    return S_prev + model(delta_t, a, b) * delta_t

# =========================================================
# FITTING (UNCHANGED LOGIC)
# =========================================================

def compute_slopes(file_path):
    df = pd.read_excel(file_path)

    col_slopes = []
    for col in df.columns:
        y = df[col].dropna().values
        x = np.arange(len(y))
        if len(y) > 1:
            slope, _, _, _, _ = linregress(x, y)
            col_slopes.append(slope)
        else:
            col_slopes.append(np.nan)

    col_slopes = np.array(col_slopes)

    freq = np.array([5, 10, 20, 40])
    delta_t = 1 / freq

    return delta_t, col_slopes

def fit_linear_model(delta_t, col_slopes):
    valid = ~np.isnan(col_slopes)

    x = 1.0 / delta_t[valid]
    y = col_slopes[valid]

    a, b, _, _, _ = linregress(x, y)
    return a, b

def get_slopes_and_fit(file_path):
    delta_t, col_slopes = compute_slopes(file_path)
    a, b = fit_linear_model(delta_t, col_slopes)

    dt_dense = np.linspace(np.min(delta_t), np.max(delta_t), 200)
    fit_curve = model(dt_dense, a, b)

    return delta_t, col_slopes, dt_dense, fit_curve, a, b

# =========================================================
# TEMPLATE (UNCHANGED)
# =========================================================

def make_normalized_template(td, tr, tmax, dt, scale_I):
    t = np.arange(0, tmax, dt)
    A = scale_I / (-(tr/td)**(td/(td-tr)) + (tr/td)**(tr/(td-tr)))
    template = A * (np.exp(-t / td) - np.exp(-t / tr))
    return t, template

# =========================================================
