import numpy as np
import matplotlib.pyplot as plt
import os
import pandas as pd
from scipy.signal import find_peaks

def zform(z1,z2, f1,f2,f):
    return z1+(z2-z1)/(f2-f1)*(f-f1)

def getiext(f, taui0, tauy0, kiy0,
            taui1, tauy1, kiy1,
            dt, r, m0, m1, b):

    pretimes = [int(i / f / dt) + 10 for i in range(0, 10)]
    extra = 500
    runtime = pretimes[-1] + extra

    # Frequency scaling for slopes and intercepts
    b0f = b
    b1f = b0f

    # Presizes for each current
    presizes0 = m0*f * np.linspace(0, runtime * dt, runtime) + b0f
    presizes1 = m1*f* np.linspace(0, runtime * dt, runtime) + b1f

    # Initialize arrays
    I0 = np.zeros(runtime)
    I1 = np.zeros(runtime)
    y0 = np.zeros(runtime)
    y1 = np.zeros(runtime)

    # Time evolution
    for i in range(0, runtime):
        if i in pretimes:
            y0[i - 1] = presizes0[i]  # reset just before update
            y1[i - 1] = presizes1[i]

        # Separate y decays
        dy0 = -y0[i - 1] / tauy0
        dy1 = -y1[i - 1] / tauy1
        y0[i] = y0[i - 1] + dy0 * dt
        y1[i] = y1[i - 1] + dy1 * dt

        # Update each current separately
        dI0 = -I0[i - 1] / taui0 + kiy0 * y0[i - 1]
        dI1 = -I1[i - 1] / taui1 + kiy1 * y1[i - 1]
        I0[i] = I0[i - 1] + dI0 * dt
        I1[i] = I1[i - 1] + dI1 * dt

    # Weighted sum for Iext
    Iext = (1 - r) * I0 + r * I1

    return Iext, I0, I1, y0, y1, runtime, presizes0, presizes1

def getstats(f, taui0, tauy0, kiy0, taui1, tauy1, kiy1, dt, r, 
                                 g, vb, C, Cr,
                                 m0, m1, b):
    # Fix fin plot
    rlist=np.linspace(0,1,100)
    tlist=[]
    rateslist=[]
    napslist=[]
    for ind,r in enumerate(rlist):
        print(ind, len(rlist))
        Iext, _, _, _, _, runtime, _, _ = getiext(f, taui0, tauy0, kiy0, taui1,
                                                  tauy1, kiy1, dt, r, m0, m1, b)
        peaks, _ = find_peaks(Iext)
        Inorm=Iext/Iext[peaks[0]]*b
        _, tmean, naps, _ = gettmean(r, Inorm, g, vb, C, Cr, f)
        rateslist.append(naps/runtime/dt)
        tlist.append(tmean)
        napslist.append(naps)
    foutlist=1/np.array(tlist)
    return rlist, foutlist, napslist

def linfun(s1,s4,fast1,fast4,f,r):
    return zform(s1,s4, 10,40,f)*(1-r)+zform(fast1,fast4, 10,40,f)*r


# New function
def gettmean(r, Iext, g, vb, C, Cr, f):
    v=np.zeros(len(Iext))
    v[0]=-60
    apinds=[]
    refper=40 # refper *dt (sec) = 4ms
    aptimer=np.inf
    posttimer=False
    gfast=zform(g[6], g[7], 10, 40, f)
    gslow=zform(g[10], g[11], 10, 40, f)
    gfast2=zform(gr[6], gr[7], 10, 40, f)
    gslow2=zform(gr[10], gr[11], 10, 40, f)
    vbslow=zform(vb[10], vb[11], 10, 40, f)
    vbfast=zform(vb[6], vb[7], 10, 40, f)
    C1=linfun(C[10], C[11], C[6], C[7], f, r)
    C2=linfun(Cr[10], Cr[11], Cr[6], Cr[7], f, r)
    
    for i in range(1,len(Iext)):
        if posttimer==False:
            icurr = r*gfast*(v[i-1]-vbfast)+(1-r)*gslow*(v[i-1]-vbslow)
            dvdt=((-icurr+Iext[i-1]))/C1
        if posttimer==True:
            icurr = r*gfast2*(v[i-1]-vbfast)+(1-r)*gslow2*(v[i-1]-vbslow)
            dvdt=((-icurr+Iext[i-1]))/C2
            
        if aptimer != np.inf:
            v[i] = v[i-1]
        else:
            v[i] = v[i-1]+dvdt*dt

        if Iext[i]>Iext[i-1]:
            posttimer=False

        if aptimer != np.inf:
            aptimer-=1
        if v[i-1]>linfun(vth[10], vth[11], vth[6], vth[7], f, r):
            v[i]=linfun(vbr[10], vbr[11], vbr[6], vbr[7], f, r)
            apinds.append(i)
            aptimer=refper
            posttimer=True
        if aptimer==0:
            aptimer=np.inf
    aptimes=np.array(apinds)*dt
    naps=len(aptimes)
    ssaptimes=aptimes[int(0.3*len(aptimes)):]
    tmean = np.mean(np.diff(ssaptimes))
    return v, tmean, naps, aptimes


