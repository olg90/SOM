def gettmean(r, Iext, g, vb, C, Cr, f):
    v=np.zeros(len(Iext))
    v[0]=-60
    apinds=[]
    refper=40 # refper *dt (sec) = 4ms
    aptimer=np.inf
    posttimer=False
