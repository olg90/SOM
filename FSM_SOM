def spike_amplitude(delta_t, slope0, A, c, H):
    return A+model(delta_t, slope0, c, H)

# model to fit
def model(delta_t, m0, c, H):
    return m0 * delta_t / (1 + (delta_t / c)**H)


def compute_slopes(file_path):
    df = pd.read_excel(file_path)

    col_slopes = []
    for col in df.columns:
        y = df[col].dropna().values
        x = np.arange(len(y))
        if len(y) > 1:
            slope, _, _, _, _ = linregress(x, y)
            col_slopes.append(slope)
        else:
            col_slopes.append(np.nan)

    col_slopes = np.array(col_slopes)

    freq = np.array([5, 10, 20, 40])
    delta_t = 1 / freq

    return delta_t, col_slopes


def fit_model(delta_t, col_slopes):
    valid = ~np.isnan(col_slopes)

    popt, _ = curve_fit(
        model,
        delta_t[valid],
        col_slopes[valid],
        p0=[1.0, 0.05, 2.0],
        maxfev=10000
    )

    m0, c, H = popt
    return m0, c, H


def get_slopes_and_fit(file_path):
    delta_t, col_slopes = compute_slopes(file_path)
    m0, c, H = fit_model(delta_t, col_slopes)

    dt_dense = np.linspace(np.min(delta_t), np.max(delta_t), 200)
    fit_curve = model(dt_dense, m0, c, H)

    return delta_t, col_slopes, dt_dense, fit_curve, m0, c, H

# original
def getiextd(f, template0, template1,
                         dt, r, p1,
                         tmax,
                         A0, A1,
                         c0, c1,
                         H0, H1,
                         slope0, slope1):

    # ---------- deterministic spike train ----------
    isi = 1.0 / f
    pretimes = np.arange(0, tmax, isi)

    spike_idx = (pretimes / dt).astype(int)

    runtime = int(tmax / dt)
    spike_idx = spike_idx[spike_idx < runtime]

    # ---------- routing + duplication ----------
    route = np.random.rand(len(spike_idx)) < r
    duplicate = np.random.rand(len(spike_idx)) < p1

    spike_y0 = list(spike_idx[~route])
    spike_y1 = list(spike_idx[route])

    spike_y0 += list(spike_idx[route & duplicate])
    spike_y1 += list(spike_idx[~route & duplicate])

    spike_y0 = np.array(sorted(spike_y0))
    spike_y1 = np.array(sorted(spike_y1))

    # ---------- ISI ----------
    isi_y0 = np.diff(spike_y0) * dt if len(spike_y0) > 1 else np.array([])
    isi_y1 = np.diff(spike_y1) * dt if len(spike_y1) > 1 else np.array([])

    # ---------- amplitudes ----------
    amps_y0 = np.zeros(len(spike_y0))
    amps_y1 = np.zeros(len(spike_y1))

    if len(spike_y0) > 0:
        amps_y0[0] = A0
    if len(spike_y1) > 0:
        amps_y1[0] = A1

    if len(spike_y0) > 1:
        amps_y0[1:] = spike_amplitude(isi_y0, slope0, A0, c0, H0)

    if len(spike_y1) > 1:
        amps_y1[1:] = spike_amplitude(isi_y1, slope1, A1, c1, H1)

    # ---------- currents ----------
    I0 = np.zeros(runtime)
    I1 = np.zeros(runtime)
    
    L0 = len(template0)
    L1 = len(template1)

    for idx, a in zip(spike_y0, amps_y0):
        end = min(idx + L0, runtime)
        I0[idx:end] += a * template0[:end - idx]

    for idx, a in zip(spike_y1, amps_y1):
        end = min(idx + L1, runtime)
        I1[idx:end] += a * template1[:end - idx]

    Iext = (1 - r) * I0 + r * I1

    return Iext, I0, I1, runtime, spike_idx, spike_y0, spike_y1


# 10 spike version
def getiextd(f, template0, template1,
             dt, r, p1,
             A0, A1,
             c0, c1,
             H0, H1,
             slope0, slope1):

    import numpy as np

    # ---------- deterministic spike train ----------
    isi = 1.0 / f
    pretimes = np.arange(0, 1000, isi)  # large placeholder horizon

    spike_idx = (pretimes / dt).astype(int)

    # keep at least 11 spikes if available
    spike_idx = spike_idx[:11]

    # ---------- define runtime as JUST BEFORE 11th spike ----------
    if len(spike_idx) >= 11:
        runtime = spike_idx[10]  # stop before 11th spike
    else:
        runtime = spike_idx[-1] + 1 if len(spike_idx) > 0 else 0

    # ---------- routing + duplication ----------
    route = np.random.rand(len(spike_idx)) < r
    duplicate = np.random.rand(len(spike_idx)) < p1

    spike_y0 = list(spike_idx[~route]) + list(spike_idx[route & duplicate])
    spike_y1 = list(spike_idx[route]) + list(spike_idx[~route & duplicate])

    spike_y0 = np.array(sorted(spike_y0))
    spike_y1 = np.array(sorted(spike_y1))

    # ---------- keep only spikes before runtime ----------
    spike_y0 = spike_y0[spike_y0 < runtime]
    spike_y1 = spike_y1[spike_y1 < runtime]

    # ---------- ISI ----------
    isi_y0 = np.diff(spike_y0) * dt if len(spike_y0) > 1 else np.array([])
    isi_y1 = np.diff(spike_y1) * dt if len(spike_y1) > 1 else np.array([])

    # ---------- increment ----------
    def increment(dt_i, slope, c, H):
        return slope * dt_i / (1 + (dt_i / c)**H)

    # ---------- amplitudes ----------
    amps_y0 = np.zeros(len(spike_y0))
    amps_y1 = np.zeros(len(spike_y1))

    # ----- slow pathway -----
    if len(spike_y0) > 0:
        A_state = A0
        amps_y0[0] = A_state

        for i in range(1, len(spike_y0)):
            dt_i = isi_y0[i-1] if len(isi_y0) > 0 else 0.0
            A_state += increment(dt_i, slope0, c0, H0)
            amps_y0[i] = A_state

    # ----- fast pathway -----
    if len(spike_y1) > 0:
        A_state = A1
        amps_y1[0] = A_state

        for i in range(1, len(spike_y1)):
            dt_i = isi_y1[i-1] if len(isi_y1) > 0 else 0.0
            A_state += increment(dt_i, slope1, c1, H1)
            amps_y1[i] = A_state

    # ---------- build signals ----------
    runtime = int(runtime) if runtime > 0 else 1

    I0 = np.zeros(runtime)
    I1 = np.zeros(runtime)

    L0 = len(template0)
    L1 = len(template1)

    for idx, a in zip(spike_y0, amps_y0):
        if idx >= runtime:
            continue
        end = min(idx + L0, runtime)
        I0[idx:end] += a * template0[:end - idx]

    for idx, a in zip(spike_y1, amps_y1):
        if idx >= runtime:
            continue
        end = min(idx + L1, runtime)
        I1[idx:end] += a * template1[:end - idx]

    Iext = (1 - r) * I0 + r * I1

    return Iext, I0, I1, runtime, spike_idx, spike_y0, spike_y1

