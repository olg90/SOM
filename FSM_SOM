import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from scipy.stats import linregress
from scipy.optimize import curve_fit


# =========================
# MODELS
# =========================

def exp_model(x, A, a):
    return A * np.exp(-a * x)

def double_exp(x, A1, a1, A2, a2):
    return A1 * np.exp(-a1 * x) + A2 * np.exp(-a2 * x)

def power_model(x, A, a, b):
    return A / (1 + a * x)**b

def stretched_exp(x, A, a, b):
    x = np.clip(x, 1e-12, None)
    return A * np.exp(-(a * x)**b)


# =========================
# DATA
# =========================

def compute_slopes(file_path):
    df = pd.read_excel(file_path)

    col_slopes = []
    for col in df.columns:
        y = df[col].dropna().values
        x = np.arange(len(y))
        if len(y) > 1:
            slope, _, _, _, _ = linregress(x, y)
            col_slopes.append(slope)
        else:
            col_slopes.append(np.nan)

    col_slopes = np.array(col_slopes)

    freq = np.array([5, 10, 20, 40])
    delta_t = 1 / freq

    return delta_t, col_slopes


# =========================
# SAFE FIT WRAPPER
# =========================

def safe_curve_fit(model, x, y, p0, bounds=(-np.inf, np.inf)):
    try:
        popt, _ = curve_fit(
            model, x, y,
            p0=p0,
            bounds=bounds,
            maxfev=50000
        )
        return popt, model(x, *popt)
    except Exception as e:
        print(f"Fit failed for {model.__name__}: {e}")
        return None, None


# =========================
# FIT + PLOT
# =========================

def fit_and_plot(x, y, title):

    valid = ~np.isnan(y)
    x = x[valid]
    y = y[valid]

    x_dense = np.linspace(np.min(x), np.max(x), 200)

    plt.figure(figsize=(6,4))
    plt.plot(x, y, 'ko', label='data')

    # ---- EXP ----
    p, _ = safe_curve_fit(exp_model, x, y,
                          p0=[np.max(y), 1.0],
                          bounds=(0, np.inf))
    if p is not None:
        plt.plot(x_dense, exp_model(x_dense, *p), label='exp')

    # ---- DOUBLE EXP ----
    p, _ = safe_curve_fit(double_exp, x, y,
                          p0=[np.max(y)/2, 1.0, np.max(y)/2, 0.1],
                          bounds=(0, np.inf))
    if p is not None:
        plt.plot(x_dense, double_exp(x_dense, *p), label='double exp')

    # ---- POWER LAW ----
    p, _ = safe_curve_fit(power_model, x, y,
                          p0=[np.max(y), 1.0, 1.0],
                          bounds=(0, np.inf))
    if p is not None:
        plt.plot(x_dense, power_model(x_dense, *p), label='power law')

    # ---- STRETCHED EXP ----
    p, _ = safe_curve_fit(stretched_exp, x, y,
                          p0=[np.max(y), 1.0, 1.0],
                          bounds=(0, np.inf))
    if p is not None:
        plt.plot(x_dense, stretched_exp(x_dense, *p), label='stretched exp')

    plt.xlabel('Δt (s)')
    plt.ylabel('slope')
    plt.title(title)
    plt.legend()
    plt.tight_layout()
    plt.show()


# =========================
# RUN
# =========================

def run(file_path, title):
    x, y = compute_slopes(file_path)
    fit_and_plot(x, y, title)


