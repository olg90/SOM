    spike_idx = spike_idx[:11]

    # ---------- define runtime as JUST BEFORE 11th spike ----------
    if len(spike_idx) >= 11:
        runtime = spike_idx[10]  # stop before 11th spike
    else:
        runtime = spike_idx[-1] + 1 if len(spike_idx) > 0 else 0

    # ---------- routing + duplication ----------
    route = np.random.rand(len(spike_idx)) < r
    duplicate = np.random.rand(len(spike_idx)) < p1

    spike_y0 = list(spike_idx[~route]) + list(spike_idx[route & duplicate])
    spike_y1 = list(spike_idx[route]) + list(spike_idx[~route & duplicate])

    spike_y0 = np.array(sorted(spike_y0))
    spike_y1 = np.array(sorted(spike_y1))

    # ---------- keep only spikes before runtime ----------
    spike_y0 = spike_y0[spike_y0 < runtime]
    spike_y1 = spike_y1[spike_y1 < runtime]

    # ---------- ISI ----------
    isi_y0 = np.diff(spike_y0) * dt if len(spike_y0) > 1 else np.array([])
    isi_y1 = np.diff(spike_y1) * dt if len(spike_y1) > 1 else np.array([])

    # ---------- increment ----------
    def increment(dt_i, slope, c, H):
        return slope * dt_i / (1 + (dt_i / c)**H)

    # ---------- amplitudes ----------
    amps_y0 = np.zeros(len(spike_y0))
    amps_y1 = np.zeros(len(spike_y1))

    # ----- slow pathway -----
    if len(spike_y0) > 0:
        A_state = A0
        amps_y0[0] = A_state

        for i in range(1, len(spike_y0)):
            dt_i = isi_y0[i-1] if len(isi_y0) > 0 else 0.0
            A_state += increment(dt_i, slope0, c0, H0)
            amps_y0[i] = A_state

    # ----- fast pathway -----
    if len(spike_y1) > 0:
        A_state = A1
        amps_y1[0] = A_state

        for i in range(1, len(spike_y1)):
            dt_i = isi_y1[i-1] if len(isi_y1) > 0 else 0.0
            A_state += increment(dt_i, slope1, c1, H1)
            amps_y1[i] = A_state

    # ---------- build signals ----------
    runtime = int(runtime) if runtime > 0 else 1

    I0 = np.zeros(runtime)
    I1 = np.zeros(runtime)

    L0 = len(template0)
    L1 = len(template1)

    for idx, a in zip(spike_y0, amps_y0):
        if idx >= runtime:
            continue
        end = min(idx + L0, runtime)
        I0[idx:end] += a * template0[:end - idx]

    for idx, a in zip(spike_y1, amps_y1):
        if idx >= runtime:
            continue
        end = min(idx + L1, runtime)
        I1[idx:end] += a * template1[:end - idx]

    Iext = (1 - r) * I0 + r * I1

    return Iext, I0, I1, runtime, spike_idx, spike_y0, spike_y1

