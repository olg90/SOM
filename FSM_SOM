import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from scipy.stats import linregress
from scipy.optimize import curve_fit


# ----------------------------
# data
# ----------------------------
def compute_slopes(file_path):
    df = pd.read_excel(file_path)

    col_slopes = []
    for col in df.columns:
        y = df[col].dropna().values
        x = np.arange(len(y))
        if len(y) > 1:
            slope, _, _, _, _ = linregress(x, y)
            col_slopes.append(slope)
        else:
            col_slopes.append(np.nan)

    col_slopes = np.array(col_slopes)

    freq = np.array([5, 10, 20, 40])
    delta_t = 1 / freq

    return delta_t, col_slopes


# ----------------------------
# safe models (important fix)
# ----------------------------
def model_rational(dt, m0, c, H):
    dt = np.maximum(dt, 1e-12)
    return m0 * dt / (1 + (dt / c) ** H)


def model_exp_sat(dt, A, B, a):
    dt = np.maximum(dt, 1e-12)
    return A + B * np.exp(-a * dt)


def model_hyperbolic(dt, A, B, c):
    dt = np.maximum(dt, 1e-12)
    return A + B / (1 + dt / c)


def model_stretched_exp(dt, A, B, a, H):
    dt = np.maximum(dt, 1e-12)
    return A + B * np.exp(-(a * dt) ** H)


# ----------------------------
# robust fit helper
# ----------------------------
def fit_model(func, x, y, p0, bounds):
    valid = ~np.isnan(y)

    popt, _ = curve_fit(
        func,
        x[valid],
        y[valid],
        p0=p0,
        bounds=bounds,
        maxfev=50000
    )
    return popt


# ----------------------------
# run fits for one dataset
# ----------------------------
def run(file_path):

    dt, slopes = compute_slopes(file_path)
    dt_dense = np.linspace(1e-6, 0.2, 400)

    p_r = fit_model(
        model_rational, dt, slopes,
        p0=[np.mean(slopes), 0.1, 1],
        bounds=([0, 1e-6, 0.1], [np.inf, 10, 10])
    )

    p_e = fit_model(
        model_exp_sat, dt, slopes,
        p0=[np.mean(slopes), 1, 1],
        bounds=([-np.inf, 0, 0], [np.inf, np.inf, 100])
    )

    p_h = fit_model(
        model_hyperbolic, dt, slopes,
        p0=[np.mean(slopes), 1, 0.1],
        bounds=([-np.inf, 0, 1e-6], [np.inf, np.inf, 10])
    )

    p_s = fit_model(
        model_stretched_exp, dt, slopes,
        p0=[np.mean(slopes), 1, 1, 1],
        bounds=([-np.inf, 0, 1e-6, 0.1], [np.inf, np.inf, 100, 5])
    )

    return dt, slopes, dt_dense, (p_r, p_e, p_h, p_s)


