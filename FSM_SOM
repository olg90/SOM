    # Step 2: Fit a best-fit line across the column slopes (x = 5,10,20,40)
    freq = np.array([5, 10, 20, 40])
    valid = ~np.isnan(col_slopes)
    slope_fit, intercept_fit, _, _, _ = linregress(freq[valid], col_slopes[valid])
    best_fit_line = intercept_fit + slope_fit * freq

    # Step 3: Plot results with matching colors
    plt.figure(figsize=(6, 4))
    for i, f in enumerate(freq):
        plt.plot(f, col_slopes[i], 'o', color=colors[i], label=f'{f} Hz point' if i == 0 else None)
    plt.plot(freq, best_fit_line, '-', color='black', label=f'Best-fit line: y={slope_fit:.4f}x+{intercept_fit:.4f}')
    
    plt.xlabel('Input frequency (Hz)')
    plt.ylabel('Slope of best fit line')
    plt.title(f'{title}: Slopes Across Frequencies')
    plt.legend()
    plt.tight_layout()
    plt.show()

    # Step 4: Return the final slope
    return slope_fit

