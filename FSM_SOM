# =========================================================
# ORIGINAL FUNCTIONS (UNCHANGED LOGIC)
# =========================================================

def spike_amplitude(delta_t, slope0, A, c, H):
    return A + slope0 * delta_t / (1 + (delta_t / c)**H)


def make_normalized_template(td, tr, tmax, dt, scale_I):
    t = np.arange(0, tmax, dt)
    A = scale_I / (-(tr/td)**(td/(td-tr)) + (tr/td)**(tr/(td-tr)))
    template = A * (np.exp(-t / td) - np.exp(-t / tr))
    return t, template


# =========================================================
# TWO SPIKE DETERMINISTIC SYSTEM (NO ROUTING, NO RANDOMNESS)
# =========================================================

def two_spike_system(
    dt,
    tmax,
    delta_t,
    temp0,
    temp1,
    A0,
    A1,
    slope0,
    slope1,
    c0,
    c1,
    H0,
    H1
):

    runtime = int(tmax / dt)

    # -------------------------
    # FIXED SPIKE TIMES
    # -------------------------
    start = 200
    spike_idx = np.array([
        start,
        start + int(delta_t / dt)
    ])

    # safety clamp
    spike_idx = np.clip(spike_idx, 0, runtime - 1)

    # -------------------------
    # separate amplitudes per branch
    # -------------------------
    amps0 = np.array([
        A0,
        spike_amplitude(delta_t, slope0, A0, c0, H0)
    ])

    amps1 = np.array([
        A1,
        spike_amplitude(delta_t, slope1, A1, c1, H1)
    ])

    # -------------------------
    # currents
    # -------------------------
    I0 = np.zeros(runtime)
    I1 = np.zeros(runtime)

    L0 = len(temp0)
    L1 = len(temp1)

    # slow branch
    for i, idx in enumerate(spike_idx):
        end = min(idx + L0, runtime)
        if end > idx:
            I0[idx:end] += amps0[i] * temp0[:end - idx]

    # fast branch
    for i, idx in enumerate(spike_idx):
        end = min(idx + L1, runtime)
        if end > idx:
            I1[idx:end] += amps1[i] * temp1[:end - idx]

    return I0, I1, spike_idx


