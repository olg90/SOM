    p_r = fit_model(
        model_rational,
        dt,
        slopes,
        p0=[1, 0.05, 2],
        bounds=([0, 1e-6, 0.1], [np.inf, 10, 10])
    )

    # exponential saturation
    p_e = fit_model(
        model_exp_sat,
        dt,
        slopes,
        p0=[np.mean(slopes), 1, 1],
        bounds=([-np.inf, 0, 0], [np.inf, np.inf, 100])
    )

    # hyperbolic
    p_h = fit_model(
        model_hyperbolic,
        dt,
        slopes,
        p0=[np.mean(slopes), 1, 0.05],
        bounds=([-np.inf, 0, 1e-6], [np.inf, np.inf, 10])
    )

    # stretched exponential
    p_s = fit_model(
        model_stretched_exp,
        dt,
        slopes,
        p0=[np.mean(slopes), 1, 1, 1],
        bounds=([-np.inf, 0, 1e-6, 0.1], [np.inf, np.inf, 100, 5])
    )

    return dt, slopes, dt_dense, (p_r, p_e, p_h, p_s)


