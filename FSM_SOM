        rateslist.append(naps/runtime/dt)
        tlist.append(tmean)
        napslist.append(naps)
    foutlist=1/np.array(tlist)
    return rlist, foutlist, napslist

def linfun(s1,s4,fast1,fast4,f,r):
    return zform(s1,s4, 10,40,f)*(1-r)+zform(fast1,fast4, 10,40,f)*r


def make_normalized_template(td, tr, tmax, dt, scale_I):
    # SynKernel = A * ( exp(-(x)/tauDecay) - exp(-(x)/tauRise) )
    t = np.arange(0, tmax, dt)
    A = scale_I / (-(tr/td)**(td/(td-tr)) + (tr/td)**(tr/(td-tr)))
    template = A * (np.exp(-t / td) - np.exp(-t / tr))
    return t, template

# def spike_amplitude(delta_t, A0, A1, c, H):
#     x = (c * delta_t)**H
#     return (A1 + A0 * x) / (1 + x)

def spike_amplitude(delta_t, slope0, A, c, H):
    return A+model(delta_t, slope0, c, H)

# model to fit
def model(delta_t, m0, c, H):
    return m0 * delta_t / (1 + (delta_t / c)**H)


def compute_slopes(file_path):
    df = pd.read_excel(file_path)

    col_slopes = []
    for col in df.columns:
        y = df[col].dropna().values
        x = np.arange(len(y))
        if len(y) > 1:
            slope, _, _, _, _ = linregress(x, y)
            col_slopes.append(slope)
        else:
            col_slopes.append(np.nan)

    col_slopes = np.array(col_slopes)

    freq = np.array([5, 10, 20, 40])
    delta_t = 1 / freq

    return delta_t, col_slopes


def fit_model(delta_t, col_slopes):
    valid = ~np.isnan(col_slopes)

    popt, _ = curve_fit(
        model,
        delta_t[valid],
        col_slopes[valid],
        p0=[1.0, 0.05, 2.0],
        maxfev=10000
    )

    m0, c, H = popt
    return m0, c, H


def get_slopes_and_fit(file_path):
    delta_t, col_slopes = compute_slopes(file_path)
    m0, c, H = fit_model(delta_t, col_slopes)

    dt_dense = np.linspace(np.min(delta_t), np.max(delta_t), 200)
    fit_curve = model(dt_dense, m0, c, H)

    return delta_t, col_slopes, dt_dense, fit_curve, m0, c, H

# original
def getiext(f, template0, template1,
            dt, r, p1,
            tmax,
            A0, A1,
            c0, c1,
            H0, H1,
            slope0, slope1):

    # ---------- generate base spike train ----------
    pretimes = []
    tcurr = 0.0
    while tcurr < tmax:
        tcurr += np.random.exponential(1.0 / f)
        pretimes.append(tcurr)

    pretimes = np.array(pretimes)
    spike_idx = (pretimes / dt).astype(int)

    runtime = int(tmax / dt)
    spike_idx = spike_idx[spike_idx < runtime]

    # ---------- routing + duplication ----------
    route = np.random.rand(len(spike_idx)) < r
    duplicate = np.random.rand(len(spike_idx)) < p1

    spike_y0 = list(spike_idx[~route])
    spike_y1 = list(spike_idx[route])

    spike_y0 += list(spike_idx[route & duplicate])
    spike_y1 += list(spike_idx[~route & duplicate])

    spike_y0 = np.array(sorted(spike_y0))
    spike_y1 = np.array(sorted(spike_y1))

    # ---------- safe ISI ----------
    isi_y0 = np.diff(spike_y0) * dt if len(spike_y0) > 1 else np.array([])
    isi_y1 = np.diff(spike_y1) * dt if len(spike_y1) > 1 else np.array([])

    # ---------- amplitudes ----------
    amps_y0 = np.zeros(len(spike_y0))
    amps_y1 = np.zeros(len(spike_y1))

    if len(spike_y0) > 0:
        amps_y0[0] = A0
    if len(spike_y1) > 0:
        amps_y1[0] = A1

    if len(spike_y0) > 1:
        amps_y0[1:] = spike_amplitude(isi_y0, slope0, A0, c0, H0)

    if len(spike_y1) > 1:
        amps_y1[1:] = spike_amplitude(isi_y1, slope1, A1, c1, H1)

    # ---------- currents ----------
    I0 = np.zeros(runtime)
    I1 = np.zeros(runtime)

    L0 = len(template0)
    L1 = len(template1)

    for idx, a in zip(spike_y0, amps_y0):
        end = min(idx + L0, runtime)
        I0[idx:end] = a * template0[:end - idx]

    for idx, a in zip(spike_y1, amps_y1):
        end = min(idx + L1, runtime)
        I1[idx:end] = a * template1[:end - idx]

    Iext = (1 - r) * I0 + r * I1

    # ---------- RETURN EVERYTHING ----------
    return Iext, I0, I1, runtime, spike_idx, spike_y0, spike_y1


# Additive up to 10
def getiext(f, template0, template1,
            dt, r, p1,
            tmax,
            A0, A1,
            c0, c1,
            H0, H1,
            slope0, slope1):

    import numpy as np

    # ---------- generate base spike train ----------
    pretimes = []
    tcurr = 0.0
    while tcurr < tmax:
        tcurr += np.random.exponential(1.0 / f)
        pretimes.append(tcurr)

    pretimes = np.array(pretimes)
    spike_idx = (pretimes / dt).astype(int)

    runtime = int(tmax / dt)
    spike_idx = spike_idx[spike_idx < runtime]

    # ---------- routing + duplication ----------
    route = np.random.rand(len(spike_idx)) < r
    duplicate = np.random.rand(len(spike_idx)) < p1

    spike_y0 = list(spike_idx[~route]) + list(spike_idx[route & duplicate])
    spike_y1 = list(spike_idx[route]) + list(spike_idx[~route & duplicate])

    spike_y0 = np.array(sorted(spike_y0))
    spike_y1 = np.array(sorted(spike_y1))

    # =========================================================
    # truncate to first 11 spikes (return only up to before 11th)
    # =========================================================
    if len(spike_y0) >= 11:
        cutoff0 = spike_y0[10]
        spike_y0 = spike_y0[:10]
    else:
        cutoff0 = runtime

    if len(spike_y1) >= 11:
        cutoff1 = spike_y1[10]
        spike_y1 = spike_y1[:10]
    else:
        cutoff1 = runtime

    runtime = min(runtime, cutoff0, cutoff1)

    # ---------- ISI ----------
    isi_y0 = np.diff(spike_y0) * dt if len(spike_y0) > 1 else np.array([])
    isi_y1 = np.diff(spike_y1) * dt if len(spike_y1) > 1 else np.array([])

    # ---------- safe increment ----------
    def increment(dt_i, slope, c, H):
        dt_i = max(dt_i, 1e-12)  # avoid divide by zero
        return slope * dt_i / (1.0 + (dt_i / (c + 1e-12))**H)

    # ---------- amplitudes ----------
    amps_y0 = np.zeros(len(spike_y0))
    amps_y1 = np.zeros(len(spike_y1))

    # ---------------- slow pathway ----------------
    if len(spike_y0) > 0:
        A_state = A0
        amps_y0[0] = A_state

        for i in range(1, len(spike_y0)):
            dt_i = isi_y0[i-1] if len(isi_y0) > 0 else 0.0
            A_state = A_state + increment(dt_i, slope0, c0, H0)
            amps_y0[i] = A_state

    # ---------------- fast pathway ----------------
    if len(spike_y1) > 0:
        A_state = A1
        amps_y1[0] = A_state

        for i in range(1, len(spike_y1)):
            dt_i = isi_y1[i-1] if len(isi_y1) > 0 else 0.0
            A_state = A_state + increment(dt_i, slope1, c1, H1)
            amps_y1[i] = A_state

    # ---------- currents ----------
    I0 = np.zeros(runtime)
    I1 = np.zeros(runtime)

    L0 = len(template0)
    L1 = len(template1)

    for idx, a in zip(spike_y0, amps_y0):
        if idx >= runtime:
            break
        end = min(idx + L0, runtime)
        I0[idx:end] += a * template0[:end - idx]

    for idx, a in zip(spike_y1, amps_y1):
        if idx >= runtime:
            break
        end = min(idx + L1, runtime)
        I1[idx:end] += a * template1[:end - idx]

    Iext = (1 - r) * I0 + r * I1

    return Iext, I0, I1, runtime, spike_idx, spike_y0, spike_y1




def gettmean(r, Iext, g, vb, C, Cr, f):
    v=np.zeros(len(Iext))
    v[0]=-60
    apinds=[]
    refper=40 # refper *dt (sec) = 4ms
    aptimer=np.inf
    posttimer=False
    gfast=zform(g[6], g[7], 10, 40, f)
    gslow=zform(g[10], g[11], 10, 40, f)
    gfast2=zform(gr[6], gr[7], 10, 40, f)
    gslow2=zform(gr[10], gr[11], 10, 40, f)
    vbslow=zform(vb[10], vb[11], 10, 40, f)
    vbfast=zform(vb[6], vb[7], 10, 40, f)
    C1=linfun(C[10], C[11], C[6], C[7], f, r)
    C2=linfun(Cr[10], Cr[11], Cr[6], Cr[7], f, r)
    vreset=linfun(vbr[10], vbr[11], vbr[6], vbr[7], f, r)
    
    for i in range(1,len(Iext)):
        if posttimer==False:
            icurr = r*gfast*(v[i-1]-vbfast)+(1-r)*gslow*(v[i-1]-vbslow)
            dvdt=((-icurr+Iext[i-1]))/C1
        if posttimer==True:
            icurr = r*gfast2*(v[i-1]-vbfast)+(1-r)*gslow2*(v[i-1]-vbslow)
            dvdt=((-icurr+Iext[i-1]))/C2
            
        if aptimer == np.inf:
            v[i] = v[i-1]+dvdt*dt
        else:
            v[i] = v[i-1]

        if Iext[i]>Iext[i-1]:
            posttimer=False

        if aptimer != np.inf:
            aptimer-=1
        if v[i-1]>linfun(vth[10], vth[11], vth[6], vth[7], f, r):
            v[i]=vreset
            apinds.append(i)
            aptimer=refper
            posttimer=True
        if aptimer==0:
            aptimer=np.inf
    aptimes=np.array(apinds)*dt
    naps=len(aptimes)
    ssaptimes=aptimes[int(0.3*len(aptimes)):]
    tmean = np.mean(np.diff(ssaptimes))
    return v, tmean, naps, aptimes

