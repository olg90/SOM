            col_slopes.append(slope)
        else:
            col_slopes.append(np.nan)

    col_slopes = np.array(col_slopes)

    freq = np.array([5, 10, 20, 40])
    delta_t = 1 / freq

    return delta_t, col_slopes


# ----------------------------
# models (stable versions)
# ----------------------------
def model_rational(dt, m0, c, H):
    dt_safe = np.maximum(dt, 1e-12)
    return m0 * dt_safe / (1 + (dt_safe / c)**H)


def model_exp_sat(dt, A, B, a):
    dt_safe = np.maximum(dt, 1e-12)
    return A + B * np.exp(-a * dt_safe)


def model_hyperbolic(dt, A, B, c):
    dt_safe = np.maximum(dt, 1e-12)
    return A + B / (1 + dt_safe / c)


def model_stretched_exp(dt, A, B, a, H):
    dt_safe = np.maximum(dt, 1e-12)
    return A + B * np.exp(-np.power(a * dt_safe, H))


# ----------------------------
# robust fitting (with bounds)
# ----------------------------
def fit_model(func, x, y, p0, bounds):
    valid = ~np.isnan(y)

    popt, _ = curve_fit(
        func,
        x[valid],
        y[valid],
        p0=p0,
        bounds=bounds,
        maxfev=50000
    )
    return popt


# ----------------------------
